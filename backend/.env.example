# Express Server Settings
PORT=3001
NODE_ENV=development

# CORS Policy
ALLOWED_ORIGIN=http://localhost:3000,https://nura-web-teal.vercel.app

# Authentication (Phase 2)
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# Database (Supabase PostgreSQL) (Phase 3)
# Supabase pooler URL — works for runtime queries
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Direct URL — required for `prisma migrate dev` (DDL statements)
# DIRECT_URL=postgresql://postgres:[DB_PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase Storage (Phase 4)
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=nuraweb-files


