generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  status        String   @default("draft") // "draft" | "published"
  type          String   @default("blog")  // "project"|"blog"|"paper"|"article"|"story"|"general"
  featured      Boolean  @default(false)
  pinned        Boolean  @default(false)
  archived      Boolean  @default(false)
  excerpt       String?
  thumbnailUrl  String?
  thumbnailAlt  String?
  authorId      String   @default("00000000-0000-0000-0000-000000000001")
  viewCount     Int      @default(0)
  likeCount     Int      @default(0)
  tags          String[] @default([])
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cells            Cell[]
  researchMetadata ResearchMetadata?
  projectMetadata  ProjectMetadata?

  @@index([status, createdAt(sort: Desc)])
  @@index([slug])
  @@index([type, status])
  @@index([featured, status])
  @@index([tags])
}

model Cell {
  id         String @id @default(cuid())
  postId     String
  type       String // "markdown" | "image" | "video" | "file"
  content    String // Stored as a raw JSON string to keep compatibility with S3 cell content structure
  orderIndex Int

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, orderIndex])
}

model ResearchMetadata {
  id                String   @id @default(cuid())
  postId            String   @unique
  publicationYear   String?
  authors           String?
  venue             String?
  abstract          String?
  keywords          String[]
  externalLinks     Json?
  pdfAttachment     String?
  researchCategory  String?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ProjectMetadata {
  id            String   @id @default(cuid())
  postId        String   @unique
  // Basic project info
  subtitle      String?
  category      String?
  role          String?
  client        String?
  teamMembers   String?
  // Timeline
  year          String?
  duration      String?
  // Links
  repoLink      String?
  demoLink      String?
  docLink       String?
  // Media / exhibition
  medium        String?
  collaborators String?
  institution   String?
  exhibition    String?
  publication   String?
  researchArea  String?
  // Project creation date (actual work date, not CMS publish date)
  projectCreationDate String?
  // Arrays
  tools         String[]
  technologies  String[]
  // Structured data
  credits       Json?
  links         Json?    // Array of {id, type, title, url, description?, order}
  references    Json?
  sections      Json?    // Array of {id, title, content, order}

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Resume {
  id        String   @id @default(cuid())
  url       String
  filename  String
  s3Key     String
  createdAt DateTime @default(now())
}

model ContentType {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

