# AWS Lambda Gateway Configuration
ALLOWED_ORIGIN=https://arunrajan6600.github.io

# JWT Authentication Configuration
JWT_SECRET=CHANGE_ME

# Admin Portal Login Credentials
ADMIN_USERNAME=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME

# AWS Infrastructure Resource Configuration
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=YOUR_BUCKET_NAME
DYNAMODB_TABLE_NAME=NuraWeb-Posts

# Optional File Manager Configurations
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/*,video/*,audio/*,application/pdf,text/*
