# =========================================================
# NuraWeb Production .gitignore
# =========================================================

# =========================================================
# Dependencies
# =========================================================
node_modules/
backend/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================================================
# Next.js
# =========================================================
.next/
out/

# =========================================================
# Backend Build
# =========================================================
backend/dist/
dist/
build/

# =========================================================
# Coverage
# =========================================================
coverage/
.nyc_output/

# =========================================================
# Environment Files
# =========================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.development

backend/.env
backend/.env.local
backend/.env.development
backend/.env.production

# Keep example files
!.env.example
!backend/.env.example

# =========================================================
# Vercel
# =========================================================
.vercel/

# =========================================================
# Serverless (Legacy AWS)
# =========================================================
.serverless/

# =========================================================
# Prisma
# =========================================================
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/*.db
backend/prisma/*.db-journal

# =========================================================
# Logs
# =========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================================
# TypeScript
# =========================================================
*.tsbuildinfo
next-env.d.ts

# =========================================================
# IDE
# =========================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# =========================================================
# OS Files
# =========================================================
.DS_Store
Thumbs.db
Desktop.ini

# =========================================================
# Python
# =========================================================
venv/
.venv/
__pycache__/
*.pyc

# =========================================================
# Temporary Files
# =========================================================
*.tmp
*.temp
*.bak
*.swp
*.swo

# =========================================================
# Certificates / Keys
# =========================================================
*.pem
*.key
*.crt
*.p12

# =========================================================
# Generated Data
# =========================================================
data/build-manifest.json
data/deployment-summary.json
.version-lock

# Versioned Posts Backups
data/backups/v*.posts.ts
data/backups/v*.build-manifest.json

# =========================================================
# Local Runtime Files
# =========================================================
.wiqi/

# =========================================================
# Miscellaneous
# =========================================================
.cache/
.eslintcache