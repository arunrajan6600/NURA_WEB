# Frontend Configuration
NEXT_PUBLIC_SITE_URL=https://arunrajan6600.github.io/nuraweb
# Express backend (local dev default):
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# AWS Lambda (legacy rollback — uncomment and comment above to revert):
# NEXT_PUBLIC_API_BASE_URL=https://lynzm5kprh.execute-api.ap-south-1.amazonaws.com/prod
NEXT_PUBLIC_DEFAULT_THEME=dark
# NEXT_PUBLIC_BASE_PATH — DO NOT set this in .env.local.
# This is a production-only variable injected automatically by GitHub Actions (value: /nuraweb).
# Setting it locally causes the dev server to only serve at /nuraweb/ and breaks all routes and assets.

# Build-time API (used by scripts/build-posts.js to fetch posts at build time)
# Express backend (local dev default):
API_BASE_URL=http://localhost:3001
# AWS Lambda (legacy rollback — uncomment and comment above to revert):
# API_BASE_URL=https://lynzm5kprh.execute-api.ap-south-1.amazonaws.com/prod
# Only required when pulling posts from a secured API endpoint:
ADMIN_USERNAME=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME

